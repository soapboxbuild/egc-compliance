                    placeholder="Add notes about this scenario..."
                    oninput="saveNotes('retrofit', this.value)"></textarea>
                <div class="notes-hint">Notes are saved automatically</div>
            </div>
        </div>
        {% endif %}
    </div>
</div>

<script>
    // Toggle accordion state
    function toggleScenario(scenario) {
        const accordion = document.getElementById('accordion-' + scenario);
        const wasOpen = accordion.classList.contains('open');

        accordion.classList.toggle('open');

        // Save state
        window.storage.set('accordion_' + scenario, !wasOpen);

        // Initialize chart if opening for first time
        if (!wasOpen && !window['chart_' + scenario]) {
            initEndUseChart(scenario);
        }
    }

    // Initialize end-use doughnut chart
    function initEndUseChart(scenario) {
        const canvas = document.getElementById('chart-' + scenario);
        if (!canvas) return;

        const ctx = canvas.getContext('2d');

        // Get data from explorer_data
        const explorerData = {{ explorer_data | tojson }};
        const scenarioData = explorerData[scenario];

        if (!scenarioData || !scenarioData.success) return;

        // Prepare chart data
        const endUses = scenarioData.end_uses;
        const labels = [];
        const data = [];
        const colors = [];

        const colorMap = {
            'heating': '#F94646',
            'cooling': '#066ECC',
            'interior_lighting': '#F7931E',
            'interior_equipment': '#7A2AEB',
            'fans': '#00BC98',
            'pumps': '#4BF7B5',
            'dhw': '#EF81DA'
        };

        for (const [endUse, values] of Object.entries(endUses)) {
            labels.push(endUse.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase()));
            data.push(values.pct);
            colors.push(colorMap[endUse] || '#808080');
        }

        // Create chart
        window['chart_' + scenario] = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{
                    data: data,
                    backgroundColor: colors,
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.label + ': ' + context.parsed + '%';
                            }
                        }
                    }
                }
            }
        });
    }

    // Save notes to storage
    function saveNotes(scenario, text) {
        window.storage.set('notes_' + scenario, text);
    }

    // Load saved notes
    function loadNotes() {
        const scenarios = ['baseline', 'reference', 'code_2022', 'retrofit'];
        scenarios.forEach(scenario => {
            const textarea = document.getElementById('notes-' + scenario);
            if (textarea) {
                const savedNotes = window.storage.get('notes_' + scenario, '');
                textarea.value = savedNotes;
            }
        });
    }

    // Restore accordion state and initialize charts
    function restoreExplorerState() {
        const scenarios = ['baseline', 'reference', 'code_2022', 'retrofit'];
        scenarios.forEach(scenario => {
            const isOpen = window.storage.get('accordion_' + scenario, false);
            if (isOpen) {
                const accordion = document.getElementById('accordion-' + scenario);
                if (accordion) {
                    accordion.classList.add('open');
                    initEndUseChart(scenario);
                }
            }
        });

        loadNotes();
    }
</script>
