                    <span class="accordion-badge-delta {{ 'positive' if results.reference.vs_baseline.eui_delta_pct < 0 else 'negative' }}">
                        {{ results.reference.vs_baseline.eui_delta_pct }}%
                    </span>
                </div>
                {% endif %}
            </div>
            {% endif %}
        </button>
        {% if explorer_data.reference.success %}
        <div class="accordion-content">
            <!-- Metrics Grid -->
            <div class="metrics-grid">
                <div class="metric-card">
                    <div class="metric-card-label">Total Energy</div>
