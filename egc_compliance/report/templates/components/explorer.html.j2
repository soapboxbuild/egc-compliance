                </div>
                <div class="metric-card">
                    <div class="metric-card-label">Unmet Cooling</div>
                    <div class="metric-card-value">{{ explorer_data.reference.summary.unmet_cooling | round(1) }}</div>
                    <div class="metric-card-unit">hours/year</div>
                </div>
            </div>

            <!-- End-Use Breakdown -->
            <div class="end-use-breakdown">
                <h4>End-Use Breakdown</h4>
                <div class="end-use-grid">
                    <div class="end-use-chart">
                        <canvas id="chart-reference"></canvas>
                    </div>
                    <div class="end-use-table">
                        <table>
                            <thead>
                                <tr>
                                    <th>End Use</th>
                                    <th style="text-align: right;">kWh/sf</th>
                                    <th style="text-align: right;">Percent</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for end_use, data in explorer_data.reference.end_uses.items() %}
                                <tr>
                                    <td>
                                        <span class="end-use-color" style="background-color: {{ {
                                            'heating': '#F94646',
                                            'cooling': '#066ECC',
                                            'interior_lighting': '#F7931E',
                                            'interior_equipment': '#7A2AEB',
                                            'fans': '#00BC98',
                                            'pumps': '#4BF7B5',
                                            'dhw': '#EF81DA'
                                        }[end_use] }};"></span>
                                        <span class="end-use-label">{{ end_use.replace('_', ' ').title() }}</span>
                                    </td>
                                    <td style="text-align: right;">{{ data.kwh_per_sf }}</td>
                                    <td style="text-align: right;">{{ data.pct }}%</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Notes -->
            <div class="notes-section">
                <h4>Notes</h4>
                <textarea class="notes-textarea" id="notes-reference"
                    placeholder="Add notes about this scenario..."
                    oninput="saveNotes('reference', this.value)"></textarea>
                <div class="notes-hint">Notes are saved automatically</div>
            </div>
        </div>
        {% endif %}
    </div>

